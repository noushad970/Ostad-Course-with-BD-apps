{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Student Score Calculator",
      "type": "shell",
      "command": "dart",
      "args": ["bin/main.dart"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "isBackground": false
    },
    {
      "label": "Get Dependencies",
      "type": "shell",
      "command": "flutter",
      "args": ["pub", "get"],
      "group": {
        "kind": "build"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Analyze Code",
      "type": "shell",
      "command": "dart",
      "args": ["analyze"],
      "group": {
        "kind": "build"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
